#!/bin/bash

if [ -f /tmp/screencap.pid ]; then
    PID=$(</tmp/screencap.pid)
    kill -s INT $PID
    rm /tmp/screencap.pid

    sleep 2

    notify-send "Uploading screencapture"

    KEY="<api key here>"
    URL="https://img.tjwiringa.nl/upload?key=$KEY"

    curl -F image=@"/tmp/screencap.mp4" $URL | jsawk 'return this.message' | xclip -selection clipboard && rm /tmp/screencap.mp4
else
    slop=$(slop -f "%x %y %w %h %g %i") || exit 1

    read -r X Y W H G ID < <(echo $slop)

    ffmpeg -loglevel quiet -f x11grab -s "$W"x"$H" -i :0.0+$X,$Y /tmp/screencap.mp4 &
    PID=$!

    echo -n $PID > /tmp/screencap.pid
fi


